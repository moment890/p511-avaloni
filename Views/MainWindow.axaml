<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:p511_890.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="p511_890.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="400"
        Height="450"
        Icon="/Assets/avalonia-logo.ico"
        Title="p511_890">
        
 <StackPanel>
      <TextBlock Margin="5" FontSize="24" HorizontalAlignment="Center" Text="Temperature Converter" />

     <Grid
      HorizontalAlignment="Center"
      Margin="5" 
      ColumnDefinitions="100, 100" 
      RowDefinitions="Auto, Auto">

    <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Celsius</TextBlock>
    <TextBox Grid.Row="0" Grid.Column="1" Margin="0 5" Text="0" TextChanged="Celsius_TextChanged" Name="Celsius"/>
    <TextBlock Grid.Row="1" Grid.Column="0" Margin="10">Fahrenheit</TextBlock>
    <TextBox Grid.Row="1" Grid.Column="1" Margin="0 5" Text="0" Name="Fahrenheit" IsReadOnly="True"/>

</Grid>

	 <Button HorizontalAlignment="Center" Click="Button_OnClick" >Caiculate</Button>
 </StackPanel>
   
  

</Window>
